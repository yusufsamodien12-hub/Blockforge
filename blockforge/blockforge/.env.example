# BlockForge configuration
#
# Easiest option: point this at the same Cloudflare Worker proxy your
# world26 project already uses -- it's a generic chat-completions proxy,
# so no new backend is needed.
VITE_PROXY_URL=https://mistralapicaller.your-subdomain.workers.dev/v1/chat/completions

# Local development only: run `npm run dev`, which starts server.js on
# port 3101, and point VITE_PROXY_URL at it instead:
# VITE_PROXY_URL=http://localhost:3101/api/mistral/chat
# MISTRAL_API_KEY=your_mistral_api_key_here
# AMBIENTCG_API_URL=https://ambientcg.com/api/v3/assets

# Direct-to-Mistral from the browser (dev only -- never ship this to a
# public static build, the key would be visible in devtools):
# VITE_MISTRAL_API_KEY=your_mistral_api_key_here
